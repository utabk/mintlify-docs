{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dokrypt",
  "colors": {
    "primary": "#f59e0b",
    "light": "#fbbf24",
    "dark": "#d97706"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/dokrypt/dokrypt"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "/installation"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "configuration/dokrypt-yaml",
              "configuration/chains",
              "configuration/services"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/snapshots",
              "features/forking",
              "features/testing",
              "features/chain-utils",
              "features/accounts",
              "features/bridge"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/plugins",
              "advanced/marketplace",
              "advanced/docker"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "cli/overview"
            ]
          },
          {
            "group": "Project Lifecycle",
            "pages": [
              "cli/init",
              "cli/up",
              "cli/down",
              "cli/restart",
              "cli/status",
              "cli/logs",
              "cli/exec"
            ]
          },
          {
            "group": "Blockchain Operations",
            "pages": [
              "cli/chain",
              "cli/fork",
              "cli/accounts",
              "cli/snapshot",
              "cli/bridge"
            ]
          },
          {
            "group": "Testing",
            "pages": [
              "cli/test"
            ]
          },
          {
            "group": "Configuration & Templates",
            "pages": [
              "cli/config",
              "cli/template",
              "cli/marketplace",
              "cli/plugin"
            ]
          },
          {
            "group": "System",
            "pages": [
              "cli/doctor",
              "cli/version"
            ]
          }
        ]
      },
      {
        "tab": "Templates",
        "groups": [
          {
            "group": "Templates",
            "pages": [
              "templates/overview",
              "templates/evm-basic",
              "templates/evm-token",
              "templates/evm-nft",
              "templates/evm-dao",
              "templates/evm-defi"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/dokrypt/dokrypt",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/dokrypt",
          "icon": "npm"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dokrypt/dokrypt"
    }
  }
}
